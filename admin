<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Fatih Admin | Düğün Anıları</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:wght@500;600;700&family=Poppins:wght@300;400;500;600&display=swap" rel="stylesheet">
    <style>
        *{box-sizing:border-box;margin:0;padding:0}
        body{font-family:'Poppins',sans-serif;background:radial-gradient(circle at top left,#fff8ea,#f7f3eb 45%,#f3eee5);color:#42372a;min-height:100vh;padding:24px}
        .wrap{max-width:1180px;margin:auto}
        .login,.panel{background:rgba(255,255,255,.78);backdrop-filter:blur(18px);border:1px solid rgba(255,255,255,.8);border-radius:32px;box-shadow:0 20px 55px rgba(0,0,0,.08)}
        .login{max-width:440px;margin:12vh auto;padding:36px;text-align:center}
        h1{font-family:'Cormorant Garamond',serif;font-size:44px;color:#8c6a31;margin-bottom:10px}
        .login p{color:#76664f;margin-bottom:22px;line-height:1.7}
        input,button{font-family:inherit}
        .login input,.search{width:100%;padding:16px;border-radius:16px;border:1px solid rgba(176,141,87,.25);background:#fffaf2;outline:none;font-size:16px}
        .login button,.refresh{width:100%;margin-top:14px;padding:16px;border:none;border-radius:999px;background:linear-gradient(135deg,#b08d57,#d4af37);color:white;font-weight:600;font-size:16px;cursor:pointer;box-shadow:0 14px 30px rgba(176,141,87,.28)}
        .panel{display:none;padding:26px}
        .top{display:flex;justify-content:space-between;gap:16px;align-items:center;flex-wrap:wrap;margin-bottom:20px}
        .top h1{margin:0}.top p{color:#776a59}.logout{background:#fff1ea;color:#9c3d2f;border:1px solid #ffd4c7;padding:12px 18px;border-radius:999px;cursor:pointer}
        .stats{display:grid;grid-template-columns:repeat(4,minmax(140px,1fr));gap:14px;margin:22px 0}
        .stat{background:#fffaf2;border:1px solid rgba(176,141,87,.18);border-radius:22px;padding:18px;box-shadow:0 10px 24px rgba(0,0,0,.04)}
        .stat span{display:block;color:#7d6c55;font-size:13px}.stat strong{font-size:28px;color:#8c6a31}
        .tools{display:flex;gap:12px;margin:18px 0;align-items:center}.refresh{width:auto;margin:0;padding:14px 22px}.search{flex:1}
        .guest{background:rgba(255,255,255,.72);border:1px solid rgba(176,141,87,.16);border-radius:24px;margin:14px 0;overflow:hidden}
        .guest-head{display:flex;justify-content:space-between;gap:12px;align-items:center;padding:18px 20px;background:#fffaf2;cursor:pointer}
        .guest-name{font-weight:700;font-size:18px;color:#6f5427}.guest-meta{color:#7d6c55;font-size:14px}.files{display:grid;grid-template-columns:repeat(auto-fill,minmax(150px,1fr));gap:12px;padding:16px;display:none}.guest.open .files{display:grid}
        .file{border-radius:18px;overflow:hidden;background:#fff;border:1px solid rgba(0,0,0,.06)}
        .thumb{height:130px;background:#f1e8d8;display:flex;align-items:center;justify-content:center;font-size:42px;color:#9b7438}.thumb img,.thumb video{width:100%;height:100%;object-fit:cover}
        .file-info{padding:10px;font-size:12px;color:#665642;word-break:break-word}.file-info a{display:inline-block;margin-top:8px;color:#8c6a31;font-weight:600;text-decoration:none}
        .empty{text-align:center;padding:36px;color:#7d6c55}.err{color:#b3261e;margin-top:12px}.ok{color:#2f7d32;margin-top:12px}
        @media(max-width:760px){body{padding:12px}.stats{grid-template-columns:repeat(2,1fr)}.tools{flex-direction:column}.refresh{width:100%}.top{display:block}.logout{margin-top:12px}.panel{padding:16px}h1{font-size:36px}}
    </style>
</head>
<body>
    <div class="wrap">
        <section class="login" id="loginBox">
            <h1>👑 Admin Paneli</h1>
            <p>Yüklenen fotoğraf ve videoları görmek için şifreyi gir.</p>
            <input id="password" type="password" placeholder="Şifre">
            <button id="loginBtn">Giriş Yap</button>
            <div id="loginMsg" class="err"></div>
        </section>

        <section class="panel" id="panel">
            <div class="top">
                <div>
                    <h1>📸 Düğün Anıları</h1>
                    <p>Yükleyen isimleri, fotoğraflar ve videolar burada listelenir.</p>
                </div>
                <button class="logout" id="logoutBtn">Çıkış</button>
            </div>

            <div class="stats">
                <div class="stat"><span>Misafir</span><strong id="guestCount">0</strong></div>
                <div class="stat"><span>Fotoğraf</span><strong id="imageCount">0</strong></div>
                <div class="stat"><span>Video</span><strong id="videoCount">0</strong></div>
                <div class="stat"><span>Toplam Dosya</span><strong id="fileCount">0</strong></div>
            </div>

            <div class="tools">
                <input class="search" id="search" placeholder="İsme göre ara...">
                <button class="refresh" id="refreshBtn">Yenile</button>
            </div>

            <div id="list" class="empty">Yükleniyor...</div>
        </section>
    </div>

<script>
const ADMIN_PASSWORD = "250825";
const SUPABASE_URL = "https://ocbxkepptjbaoqwvrzuw.supabase.co";
const SUPABASE_KEY = "sb_publishable_1Wz11hgmmieGxZcfjWJzIA_vUDzBsEN";
let uploads = [];

const loginBox = document.getElementById("loginBox");
const panel = document.getElementById("panel");
const list = document.getElementById("list");
const search = document.getElementById("search");

function isLoggedIn(){ return localStorage.getItem("wedding_admin") === "yes"; }
function showPanel(){ loginBox.style.display="none"; panel.style.display="block"; loadUploads(); }
function showLogin(){ loginBox.style.display="block"; panel.style.display="none"; }

function fileIcon(type){ return type === "video" ? "🎥" : "📸"; }
function safeName(name){ return (name || "Misafir").trim() || "Misafir"; }

async function loadUploads(){
    list.className = "empty";
    list.innerHTML = "Yükleniyor...";
    try{
        const res = await fetch(`${SUPABASE_URL}/rest/v1/wedding_uploads?select=*&order=uploaded_at.desc`, {
            headers:{ apikey: SUPABASE_KEY, Authorization: `Bearer ${SUPABASE_KEY}` }
        });
        if(!res.ok) throw new Error(await res.text());
        uploads = await res.json();
        render();
    }catch(err){
        console.error(err);
        list.className = "empty err";
        list.innerHTML = "Veriler alınamadı. Supabase tablo/policy ayarlarını kontrol et.";
    }
}

function render(){
    const q = search.value.toLowerCase().trim();
    const filtered = uploads.filter(u => safeName(u.guest_name).toLowerCase().includes(q));
    const groups = new Map();
    filtered.forEach(u => {
        const name = safeName(u.guest_name);
        if(!groups.has(name)) groups.set(name, []);
        groups.get(name).push(u);
    });

    const imageCount = filtered.filter(u => u.file_type === "image").length;
    const videoCount = filtered.filter(u => u.file_type === "video").length;
    document.getElementById("guestCount").textContent = groups.size;
    document.getElementById("imageCount").textContent = imageCount;
    document.getElementById("videoCount").textContent = videoCount;
    document.getElementById("fileCount").textContent = filtered.length;

    if(!filtered.length){
        list.className = "empty";
        list.innerHTML = "Henüz yükleme yok.";
        return;
    }

    list.className = "";
    list.innerHTML = Array.from(groups.entries()).map(([name, items]) => {
        const img = items.filter(i => i.file_type === "image").length;
        const vid = items.filter(i => i.file_type === "video").length;
        const files = items.map(item => {
            const isVideo = item.file_type === "video";
            const preview = isVideo
                ? `<video src="${item.file_url}" controls muted></video>`
                : `<img src="${item.file_url}" alt="${item.file_name || ''}">`;
            const date = item.uploaded_at ? new Date(item.uploaded_at).toLocaleString("tr-TR") : "";
            return `<div class="file">
                <div class="thumb">${preview}</div>
                <div class="file-info">
                    <div>${fileIcon(item.file_type)} ${item.file_name || "Dosya"}</div>
                    <div>${date}</div>
                    <a href="${item.file_url}" target="_blank" download>İndir / Aç</a>
                </div>
            </div>`;
        }).join("");
        return `<div class="guest">
            <div class="guest-head" onclick="this.parentElement.classList.toggle('open')">
                <div>
                    <div class="guest-name">👤 ${name}</div>
                    <div class="guest-meta">📸 ${img} fotoğraf • 🎥 ${vid} video</div>
                </div>
                <div>Göster ↓</div>
            </div>
            <div class="files">${files}</div>
        </div>`;
    }).join("");
}

document.getElementById("loginBtn").addEventListener("click", () => {
    const pass = document.getElementById("password").value;
    if(pass === ADMIN_PASSWORD){
        localStorage.setItem("wedding_admin", "yes");
        showPanel();
    }else{
        document.getElementById("loginMsg").textContent = "Şifre hatalı.";
    }
});

document.getElementById("password").addEventListener("keydown", e => {
    if(e.key === "Enter") document.getElementById("loginBtn").click();
});

document.getElementById("logoutBtn").addEventListener("click", () => {
    localStorage.removeItem("wedding_admin");
    showLogin();
});

document.getElementById("refreshBtn").addEventListener("click", loadUploads);
search.addEventListener("input", render);

if(isLoggedIn()) showPanel(); else showLogin();
</script>
</body>
</html>
