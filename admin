<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Yüklenen Anılar | Admin</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:wght@500;600;700&family=Poppins:wght@300;400;500;600&display=swap" rel="stylesheet">
    <style>
        *{box-sizing:border-box;margin:0;padding:0}
        body{font-family:'Poppins',sans-serif;background:radial-gradient(circle at top left,#fff8ea,#f7f3eb 45%,#f3eee5);color:#3f3527;min-height:100vh;padding:28px}
        .wrap{max-width:1200px;margin:auto}
        .hero{background:rgba(255,255,255,.78);backdrop-filter:blur(18px);border:1px solid rgba(255,255,255,.75);box-shadow:0 20px 55px rgba(0,0,0,.08);border-radius:30px;padding:34px;margin-bottom:24px;text-align:center}
        h1{font-family:'Cormorant Garamond',serif;font-size:46px;color:#8c6a31;margin-bottom:10px}
        .muted{color:#746957;line-height:1.7}
        .stats{display:grid;grid-template-columns:repeat(auto-fit,minmax(180px,1fr));gap:16px;margin:22px 0}
        .stat{background:#fffaf2;border:1px solid #ead8ae;border-radius:22px;padding:20px;text-align:center;box-shadow:0 12px 30px rgba(0,0,0,.05)}
        .stat strong{display:block;font-size:34px;color:#9b7438}
        .actions{display:flex;gap:12px;flex-wrap:wrap;justify-content:center;margin-top:18px}
        button,a.btn{border:none;border-radius:999px;padding:13px 22px;background:linear-gradient(135deg,#b08d57,#d4af37);color:white;font-weight:600;cursor:pointer;text-decoration:none;box-shadow:0 12px 26px rgba(176,141,87,.24)}
        .grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(230px,1fr));gap:18px}
        .card{background:rgba(255,255,255,.82);border:1px solid rgba(255,255,255,.8);border-radius:24px;overflow:hidden;box-shadow:0 14px 35px rgba(0,0,0,.08)}
        .thumb{height:190px;background:#f0e4cf;display:flex;align-items:center;justify-content:center;overflow:hidden}
        .thumb img,.thumb video{width:100%;height:100%;object-fit:cover}
        .video-mark{font-size:58px}
        .info{padding:16px}
        .name{font-weight:700;color:#7b5a2e;margin-bottom:6px}
        .date,.file{font-size:13px;color:#776b5b;margin-bottom:6px;word-break:break-word}
        .info a{display:inline-block;margin-top:10px;color:#9b7438;font-weight:600;text-decoration:none}
        .empty{background:rgba(255,255,255,.8);border-radius:24px;padding:40px;text-align:center;color:#776b5b}
        @media(max-width:600px){body{padding:16px}h1{font-size:34px}.hero{padding:24px}.thumb{height:170px}}
    </style>
</head>
<body>
    <div class="wrap">
        <div class="hero">
            <h1>📸 Yüklenen Anılar</h1>
            <p class="muted">Misafirlerin yüklediği fotoğraf ve videolar burada isimleriyle listelenir.</p>
            <div class="stats">
                <div class="stat"><strong id="totalCount">0</strong><span>Toplam</span></div>
                <div class="stat"><strong id="photoCount">0</strong><span>Fotoğraf</span></div>
                <div class="stat"><strong id="videoCount">0</strong><span>Video</span></div>
                <div class="stat"><strong id="guestCount">0</strong><span>Misafir</span></div>
            </div>
            <div class="actions">
                <button id="refreshBtn">Yenile</button>
                <a class="btn" href="index.html#upload">Yükleme Sayfası</a>
            </div>
        </div>
        <div id="uploadGrid" class="grid"></div>
    </div>

<script>
const SUPABASE_URL = "https://ocbxkepptjbaoqwvrzuw.supabase.co";
const SUPABASE_KEY = "sb_publishable_1Wz11hgmmieGxZcfjWJzIA_vUDzBsEN";
const grid = document.getElementById("uploadGrid");
const refreshBtn = document.getElementById("refreshBtn");

function formatDate(value){
    if(!value) return "";
    return new Date(value).toLocaleString("tr-TR", { dateStyle:"medium", timeStyle:"short" });
}

function isVideo(item){
    return (item.file_type || "").includes("video") || /\.(mp4|mov|webm|m4v)$/i.test(item.file_name || item.file_url || "");
}

async function loadUploads(){
    grid.innerHTML = `<div class="empty">Yüklemeler getiriliyor...</div>`;
    const response = await fetch(`${SUPABASE_URL}/rest/v1/wedding_uploads?select=*&order=uploaded_at.desc`, {
        headers: {
            "apikey": SUPABASE_KEY,
            "Authorization": `Bearer ${SUPABASE_KEY}`
        }
    });

    if(!response.ok){
        grid.innerHTML = `<div class="empty">Kayıtlar getirilemedi. Supabase RLS/policy ayarlarını kontrol et.</div>`;
        return;
    }

    const data = await response.json();
    const photos = data.filter(item => !isVideo(item)).length;
    const videos = data.filter(item => isVideo(item)).length;
    const guests = new Set(data.map(item => item.guest_name || "İsimsiz")).size;

    document.getElementById("totalCount").textContent = data.length;
    document.getElementById("photoCount").textContent = photos;
    document.getElementById("videoCount").textContent = videos;
    document.getElementById("guestCount").textContent = guests;

    if(data.length === 0){
        grid.innerHTML = `<div class="empty">Henüz yükleme yok.</div>`;
        return;
    }

    grid.innerHTML = data.map(item => {
        const video = isVideo(item);
        const media = video
            ? `<video src="${item.file_url}" controls muted></video>`
            : `<img src="${item.file_url}" alt="${item.file_name || 'Fotoğraf'}">`;
        return `
            <article class="card">
                <div class="thumb">${media}</div>
                <div class="info">
                    <div class="name">👤 ${item.guest_name || "İsimsiz"}</div>
                    <div class="date">🕒 ${formatDate(item.uploaded_at)}</div>
                    <div class="file">${video ? "🎥" : "📸"} ${item.file_name || "Dosya"}</div>
                    <a href="${item.file_url}" target="_blank" rel="noopener">Dosyayı Aç / İndir</a>
                </div>
            </article>
        `;
    }).join("");
}

refreshBtn.addEventListener("click", loadUploads);
loadUploads();
</script>
</body>
</html>
